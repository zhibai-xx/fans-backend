# 数据库连接
DATABASE_URL="postgresql://username:password@localhost:5432/mydatabase?schema=public"

# 应用配置
PORT=3000
NODE_ENV=development
JWT_SECRET="replace-with-a-strong-random-secret"
JWT_REFRESH_SECRET="replace-with-other-strong-random-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"
CORS_ORIGINS="http://localhost:3001,http://127.0.0.1:3001"
LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
LOGIN_RATE_LIMIT_MAX_IP_ATTEMPTS=30
LOGIN_LOCK_WINDOW_SECONDS=600
LOGIN_LOCK_MAX_FAILURES_IP=8
LOGIN_LOCK_MAX_FAILURES_USERNAME=5
LOGIN_LOCK_DURATION_SECONDS=900

# Redis / BullMQ 配置
REDIS_HOST="127.0.0.1"
REDIS_PORT=6379
REDIS_PASSWORD=""
REDIS_DB=0

# 下载签名密钥（建议与 JWT_SECRET 区分）
DOWNLOAD_SIGN_SECRET="replace-with-download-sign-secret"

# 功能开关
ENABLE_VIDEO_FEATURE=false
TRUST_PROXY=false
BODY_PARSER_DEBUG=false

# 存储配置
USE_OSS_STORAGE=false # 设置为true启用阿里云OSS存储，false使用本地存储

# 本地存储配置
LOCAL_UPLOAD_DIR="./uploads" # 本地存储路径

# 阿里云OSS配置
OSS_ACCESS_KEY_ID="your_access_key_id"
OSS_ACCESS_KEY_SECRET="your_access_key_secret"
OSS_BUCKET="your_bucket_name"
OSS_REGION="oss-cn-beijing" # 例如：oss-cn-beijing, oss-cn-shanghai等
OSS_ENDPOINT="oss-cn-beijing.aliyuncs.com"
OSS_CDN_BASE_URL="https://your-cdn-domain.com" # 可选：CDN访问URL前缀 
