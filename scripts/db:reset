#!/usr/bin/env bash
# Dependencies: node (npm), docker, prisma CLI
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage: scripts/db:reset [--dry-run]

Rebuilds the test database using Prisma migrations and seeds.
Options:
  --dry-run   Show the commands that would run without executing them.
  -h, --help  Show this help message.
USAGE
}

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

DRY_RUN=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run)
      DRY_RUN=true
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

export NODE_ENV="test"
RESET_CMD=(npx prisma migrate reset --force --skip-seed --schema "$ROOT_DIR/prisma/schema.prisma")
SEED_CMD=(npm run db:seed)

if [[ "$DRY_RUN" == true ]]; then
  echo "[db:reset] (dry-run) ${RESET_CMD[*]}"
  echo "[db:reset] (dry-run) ${SEED_CMD[*]}"
  exit 0
fi

echo "[db:reset] Resetting Prisma test database..."
"${RESET_CMD[@]}"

echo "[db:reset] Seeding database..."
"${SEED_CMD[@]}"

printf '\n[db:reset] Done. Current environment: %s\n' "$NODE_ENV"
