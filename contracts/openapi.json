{
  "openapi": "3.0.3",
  "info": {
    "title": "Fans Backend API",
    "version": "1.0.0",
    "description": "Contract snapshot for fans-backend generated via DocumentBuilder defaults."
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local development"
    }
  ],
  "tags": [
    {
      "name": "Auth",
      "description": "Authentication endpoints"
    },
    {
      "name": "Upload",
      "description": "File upload endpoints"
    },
    {
      "name": "User",
      "description": "User profile endpoints"
    }
  ],
  "paths": {
    "/api/users/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Login with credentials",
        "operationId": "login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful login",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/upload/chunks": {
      "post": {
        "tags": [
          "Upload"
        ],
        "summary": "Upload file chunk",
        "operationId": "uploadChunk",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/ChunkUploadRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Chunk accepted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChunkUploadResponse"
                }
              }
            }
          },
          "413": {
            "description": "File too large",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/users/me": {
      "get": {
        "tags": [
          "User"
        ],
        "summary": "Get current user",
        "operationId": "getCurrentUser",
        "responses": {
          "200": {
            "description": "Current user payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserProfileResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "LoginRequest": {
        "type": "object",
        "required": [
          "email",
          "password"
        ],
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string",
            "minLength": 6
          }
        }
      },
      "AuthResponse": {
        "type": "object",
        "required": [
          "token",
          "user"
        ],
        "properties": {
          "token": {
            "type": "string",
            "description": "JWT token"
          },
          "user": {
            "$ref": "#/components/schemas/User"
          }
        }
      },
      "User": {
        "type": "object",
        "required": [
          "id",
          "uuid",
          "email"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "uuid": {
            "type": "string",
            "format": "uuid"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "nickname": {
            "type": "string"
          },
          "avatarUrl": {
            "type": "string",
            "format": "uri"
          }
        }
      },
      "UserProfileResponse": {
        "type": "object",
        "required": [
          "data"
        ],
        "properties": {
          "data": {
            "$ref": "#/components/schemas/User"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": [
          "statusCode",
          "timestamp",
          "path",
          "message",
          "error"
        ],
        "properties": {
          "statusCode": {
            "type": "integer"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "path": {
            "type": "string"
          },
          "message": {
            "type": "string",
            "description": "Semicolon-delimited error message"
          },
          "error": {
            "type": "string"
          }
        }
      },
      "ChunkUploadRequest": {
        "type": "object",
        "required": [
          "file",
          "chunkIndex",
          "chunkTotal",
          "fileUuid",
          "chunkSize"
        ],
        "properties": {
          "file": {
            "type": "string",
            "format": "binary",
            "description": "Chunk binary payload"
          },
          "chunkIndex": {
            "type": "integer",
            "minimum": 0
          },
          "chunkTotal": {
            "type": "integer",
            "minimum": 1
          },
          "fileUuid": {
            "type": "string",
            "format": "uuid"
          },
          "chunkSize": {
            "type": "integer",
            "description": "Chunk size in bytes",
            "maximum": 52428800
          }
        }
      },
      "ChunkUploadResponse": {
        "type": "object",
        "required": [
          "received",
          "fileUuid"
        ],
        "properties": {
          "received": {
            "type": "boolean"
          },
          "fileUuid": {
            "type": "string",
            "format": "uuid"
          },
          "nextChunk": {
            "type": "integer",
            "nullable": true
          }
        }
      }
    }
  }
}
