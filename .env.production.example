DATABASE_URL="postgresql://idol_user:replace-password@your-rds-host:5432/idol_db?schema=public"

PORT=3000
NODE_ENV=production
JWT_SECRET="replace-with-a-strong-random-secret"
JWT_REFRESH_SECRET="replace-with-another-strong-random-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"
DOWNLOAD_SIGN_SECRET="replace-with-download-sign-secret"

CORS_ORIGINS="https://enjoycorner.com,https://www.enjoycorner.com"
LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
LOGIN_RATE_LIMIT_MAX_IP_ATTEMPTS=30
LOGIN_LOCK_WINDOW_SECONDS=600
LOGIN_LOCK_MAX_FAILURES_IP=8
LOGIN_LOCK_MAX_FAILURES_USERNAME=5
LOGIN_LOCK_DURATION_SECONDS=900

REDIS_HOST="redis"
REDIS_PORT=6379
REDIS_PASSWORD=""
REDIS_DB=0

ENABLE_VIDEO_FEATURE=false
TRUST_PROXY=true
BODY_PARSER_DEBUG=false
ENABLE_SWAGGER=false

USE_OSS_STORAGE=true
LOCAL_UPLOAD_DIR="./uploads"
UPLOAD_DIR="./uploads"

OSS_ACCESS_KEY_ID="your-access-key-id"
OSS_ACCESS_KEY_SECRET="your-access-key-secret"
OSS_BUCKET="your-bucket-name"
OSS_REGION="oss-cn-hangzhou"
OSS_ENDPOINT="oss-cn-hangzhou.aliyuncs.com"
OSS_CDN_BASE_URL="https://your-cdn-domain.com"
